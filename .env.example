# Protocols — Environment Variables
# Copy to .env and fill in your values

# API
PROTOCOLS_DATABASE_URL=postgresql+asyncpg://protocols:protocols-dev-password@localhost:5432/protocols
PROTOCOLS_REDIS_URL=redis://localhost:6379/0
PROTOCOLS_JWT_SECRET_KEY=change-me-in-production

# AI (Claude API)
ANTHROPIC_API_KEY=sk-ant-...
PROTOCOLS_ANTHROPIC_API_KEY=sk-ant-...
PROTOCOLS_AI_MODEL=claude-sonnet-4-20250514

# Server
PROTOCOLS_HOST=0.0.0.0
PROTOCOLS_PORT=8000
PROTOCOLS_CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:19006"]
